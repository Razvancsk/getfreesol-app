# Database
DATABASE_URL=postgresql://user:password@host/dbname

# Solana / Helius
HELIUS_API_KEY=your_helius_api_key
HELIUS_RPC_URL=https://mainnet.helius-rpc.com/?api-key=your_helius_api_key
SOLANA_RPC_API_KEY=your_solana_rpc_api_key

# Jupiter
JUPITER_API_KEY=your_jupiter_api_key

# OpenAI
OPENAI_API_KEY=your_openai_api_key
AI_INTEGRATIONS_OPENAI_API_KEY=your_openai_api_key
AI_INTEGRATIONS_OPENAI_BASE_URL=https://api.openai.com/v1

# X (Twitter)
X_API_KEY=your_x_api_key
X_API_SECRET=your_x_api_secret

# Discord
DISCORD_BOT_TOKEN=your_discord_bot_token
DISCORD_WEBHOOK_URL=your_discord_webhook_url
DISCORD_CHECK_WEBHOOK_URL=your_discord_check_webhook_url

# Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token

# Backpack Exchange
Backpack_api_key=your_backpack_api_key
Backpack_api_secret=your_backpack_api_secret

# Sanctum
SANCTUM_API_KEY=your_sanctum_api_key

# Wallet / Security
FEES_WALLET=your_fees_wallet_public_key
FEES_WALLET_COINFLIP=your_coinflip_fees_wallet_public_key
RELAYER_PRIVATE_KEY=your_relayer_private_key_base58
FEE_ACCOUNT_ENCRYPTION_KEY=your_32_byte_hex_encryption_key

# Admin
ADMIN_SECRET=your_admin_secret
VAULT_ADMIN_SECRET=your_vault_admin_secret

# Push Notifications (VAPID)
VAPID_PUBLIC_KEY=your_vapid_public_key
VAPID_PRIVATE_KEY=your_vapid_private_key

# Phantom Bot
phantom_bot=your_phantom_bot_token

# Server
PORT=5000
NODE_ENV=development
